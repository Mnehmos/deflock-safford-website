# DeFlock Safford petition API — environment template
#
# Copy this to ".env" for LOCAL testing only. The real ".env" is gitignored
# and must NEVER be committed. In production, set these as Railway variables.
#
# Get these from your Supabase project: Settings → API.

# Your Supabase project URL
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# The service_role key (SECRET — server-side only, never in the browser or git)
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# Your site origin(s), comma-separated. Locks down who can POST to this API.
ALLOWED_ORIGIN=https://mnehmos.github.io

# Local port (Railway sets PORT automatically in production)
PORT=8080
