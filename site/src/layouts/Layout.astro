---
interface Props {
  title: string;
  description?: string;
  accent?: string;
}

const {
  title,
  description = "DeFlock Safford — Mass surveillance came to Graham County. Here's what it does, who can see it, and how to push back.",
  accent = "#E63946"
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | DeFlock Safford</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style is:global define:vars={{ accent }}>
    :root {
      /* City of Safford civic palette: navy + azure on warm off-white (Claude light-mode register). DeFlock red kept for action. */
      --color-bg: #faf9f5;          /* warm off-white page background */
      --color-surface: #f3f1ea;     /* card / panel surface, slightly deeper warm tone */
      --color-text: #1a2b42;
      --color-muted: #5a6b80;
      --color-navy: #1B3D6D;      /* City of Safford header navy */
      --color-azure: #2E6DB4;     /* City service-icon blue */
      --color-cyan: #3E92CC;      /* City search-button blue */
      --color-border: #e0ddd2;    /* warm border to match off-white */
      --color-accent: var(--accent);   /* DeFlock red #E63946 for action/petition */
      --font-heading: 'Space Grotesk', system-ui, sans-serif;
      --font-body: 'Inter', system-ui, sans-serif;
      --max-width: 720px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 1.0625rem;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 { font-family: var(--font-heading); line-height: 1.2; color: var(--color-navy); }
    h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; }
    h2 { font-size: 1.75rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--color-navy); }
    h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; }

    p { margin-bottom: 1rem; }
    a { color: var(--color-azure); text-decoration: none; }
    a:hover { text-decoration: underline; }

    blockquote {
      border-left: 3px solid var(--color-navy);
      padding-left: 1.5rem;
      margin: 1.5rem 0;
      color: var(--color-muted);
      font-style: italic;
    }

    code {
      font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
      font-size: 0.9em;
      background: #ece8dd;
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
      color: #1a2b42;
    }

    /* NAV - City of Safford navy bar */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--color-navy);
      border-bottom: 3px solid var(--color-cyan);
    }
    .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 0.75rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #ffffff;
      line-height: 1.1;
    }
    .nav-brand small {
      display: block;
      font-size: 0.6rem;
      font-weight: 400;
      letter-spacing: 0.5px;
      text-transform: none;
      color: #b9cce4;
      margin-top: 2px;
    }
    .nav-brand:hover { text-decoration: none; }
    .nav-links {
      list-style: none;
      display: flex;
      gap: 0.9rem;
      align-items: center;
    }
    .nav-links a {
      font-size: 0.85rem;
      color: #dce6f2;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #ffffff; text-decoration: none; }
    .nav-links .act-link {
      background: var(--color-accent);
      color: #ffffff;
      padding: 0.4rem 0.9rem;
      border-radius: 4px;
      font-weight: 600;
    }
    .nav-links .act-link:hover { opacity: 0.92; color: #fff; }

    /* DROPDOWN */
    .nav-dropdown { position: relative; }
    .nav-dropdown-toggle { cursor: pointer; }
    .dropdown-arrow { font-size: 0.65em; margin-left: 2px; }
    .nav-dropdown-menu {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      background: #141414;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 0.5rem 0;
      min-width: 200px;
      list-style: none;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      z-index: 200;
    }
    .nav-dropdown-menu::before {
      content: '';
      position: absolute;
      top: -0.5rem; left: 0; right: 0; height: 0.5rem;
    }
    .nav-dropdown:hover .nav-dropdown-menu { display: block; }
    .nav-dropdown-menu li { list-style: none; }
    .nav-dropdown-menu a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 1rem;
      font-size: 0.85rem;
      color: var(--color-muted);
      white-space: nowrap;
      transition: color 0.15s, background 0.15s;
    }
    .nav-dropdown-menu a:hover { color: var(--color-text); background: rgba(255,255,255,0.05); }
    .nav-dot {
      display: inline-block; width: 8px; height: 8px;
      border-radius: 50%; flex-shrink: 0;
    }

    .hamburger {
      display: none; background: none; border: none;
      color: #ffffff; font-size: 1.5rem; cursor: pointer;
    }

    /* MAIN CONTENT */
    .content { max-width: var(--max-width); margin: 0 auto; padding: 3rem 1.5rem; }

    .hero {
      text-align: center;
      padding: 4rem 1.5rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .hero .tagline {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--color-muted);
      margin-bottom: 0.5rem;
    }
    .hero h1 { font-size: 3rem; }
    .hero .subtitle {
      font-size: 1.25rem;
      color: var(--color-muted);
      max-width: 620px;
      margin: 1.5rem auto;
    }

    /* BUTTONS */
    .btn {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: var(--color-accent);
      color: #ffffff;
      font-weight: 600;
      font-family: var(--font-heading);
      border-radius: 4px;
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
      margin: 0.5rem;
    }
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(230, 57, 70, 0.35);
      text-decoration: none;
      color: #ffffff;
    }
    .btn-outline {
      background: transparent;
      border: 2px solid var(--color-navy);
      color: var(--color-navy);
    }
    .btn-outline:hover { box-shadow: 0 4px 16px rgba(27, 61, 109, 0.25); color: var(--color-navy); }

    /* RECEIPT / FACT CARD */
    .card {
      background: #ffffff;
      border: 1px solid var(--color-border);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
      transition: border-color 0.2s, box-shadow 0.2s;
      text-decoration: none;
      display: block;
      color: inherit;
      box-shadow: 0 1px 2px rgba(27, 61, 109, 0.04);
    }
    .card:hover { border-color: var(--color-azure); box-shadow: 0 4px 16px rgba(27,61,109,0.08); text-decoration: none; }
    .card h3 { margin-top: 0; color: var(--color-navy); }
    .card p { color: var(--color-muted); margin-bottom: 0.75rem; }
    .card-specifics { list-style: none; padding: 0; margin: 0; }
    .card-specifics li {
      position: relative;
      padding-left: 1.25rem;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      color: var(--color-muted);
      line-height: 1.5;
    }
    .card-specifics li::before {
      content: '\2192';
      position: absolute; left: 0;
      color: var(--color-azure);
    }
    .card-specifics li strong { color: var(--color-navy); }
    .card-tag {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 0.25rem 0.6rem;
      border-radius: 3px;
      margin-bottom: 0.75rem;
      color: #ffffff;
      background: var(--color-navy);
    }
    .card-tag.tag-act { background: var(--color-accent); }
    .card-tag.tag-proof { background: var(--color-accent); }
    .card-tag.tag-architecture { background: #6b3fa0; }
    .card-tag.tag-civic { background: var(--color-azure); }

    /* SOURCE LINE */
    .source {
      font-size: 0.8rem;
      color: #7a8aa0;
      margin-top: 0.5rem;
      font-style: italic;
    }
    .source a { color: var(--color-azure); }

    /* CTA BANNER */
    .cta-banner {
      background: var(--color-navy);
      border: 1px solid var(--color-navy);
      border-radius: 8px;
      padding: 2rem;
      margin: 3rem 0;
      text-align: center;
    }
    .cta-banner h3 { color: #ffffff; margin-top: 0; }
    .cta-banner p { color: #cfdcec; }

    /* STAT */
    .stat-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin: 2rem 0;
    }
    .stat {
      background: #ffffff;
      padding: 1.25rem;
      border-radius: 8px;
      text-align: center;
    }
    .stat {
      border: 1px solid var(--color-border);
    }
    .stat-number {
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-navy);
    }
    .stat-label { font-size: 0.85rem; color: var(--color-muted); }

    /* CODE BLOCK (for the records request) */
    .codeblock {
      background: #f3f1ea;
      border: 1px solid var(--color-border);
      border-left: 4px solid var(--color-navy);
      border-radius: 8px;
      padding: 1.5rem;
      margin: 1.5rem 0;
      font-family: ui-monospace, 'Cascadia Code', monospace;
      font-size: 0.85rem;
      line-height: 1.6;
      color: #2a3b52;
      white-space: pre-wrap;
      overflow-x: auto;
    }

    /* CALENDAR VISUALIZER */
    .cal {
      background: var(--color-surface);
      border: 1px solid #222;
      border-radius: 8px;
      padding: 1.25rem;
      margin: 1rem 0;
    }
    .cal-title {
      font-family: var(--font-heading);
      font-weight: 600;
      text-align: center;
      margin-bottom: 0.75rem;
    }
    .cal-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
    }
    .cal-dow {
      text-align: center;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--color-muted);
      padding-bottom: 0.25rem;
    }
    .cal-day {
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      border-radius: 5px;
      color: var(--color-text);
    }
    .cal-day.empty { color: transparent; }
    .cal-day.meeting {
      background: var(--color-accent);
      color: var(--color-bg);
      font-weight: 700;
    }
    .cal-day.meeting-alt {
      border: 2px solid var(--color-accent);
      color: var(--color-accent);
      font-weight: 700;
    }
    .cal-legend {
      display: flex;
      gap: 1.25rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 0.85rem;
      font-size: 0.8rem;
      color: var(--color-muted);
    }
    .cal-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
    .cal-swatch { width: 14px; height: 14px; border-radius: 3px; display: inline-block; }

    /* FOOTER */
    .footer {
      margin-top: 4rem;
      padding: 2rem;
      background: var(--color-navy);
      text-align: center;
      font-size: 0.85rem;
      color: #cfdcec;
      border-top: 3px solid var(--color-cyan);
    }
    .footer p strong { color: #ffffff; }
    .footer a { color: #9fc0e6; }
    .footer-links { margin-top: 1rem; }
    .footer-links a { margin: 0 0.5rem; }

    /* MOBILE */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%; left: 0; right: 0;
        background: var(--color-navy);
        border-bottom: 3px solid var(--color-cyan);
        padding: 1rem;
      }
      .hamburger { display: block; }
      .nav-dropdown-menu {
        position: static; transform: none;
        background: transparent; border: none;
        box-shadow: none; padding: 0 0 0 0.75rem; min-width: 0;
      }
      .nav-dropdown-menu::before { display: none; }
      .nav-links.open .nav-dropdown .nav-dropdown-menu { display: block; }
      .nav-dropdown-menu a { padding: 0.3rem 0.5rem; font-size: 0.8rem; }
      .hero h1 { font-size: 2rem; }
      h1 { font-size: 1.75rem; }
      h2 { font-size: 1.4rem; }
      .stat-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href={base} class="nav-brand">DeFlock Safford<small>Independent residents' project &middot; not the City of Safford</small></a>
      <button class="hamburger" aria-label="Menu" id="menu-toggle">&#9776;</button>
      <ul class="nav-links" id="nav-links">
        <li><a href={base}>The Problem</a></li>
        <li><a href={`${base}proof/`}>Proof It Works</a></li>
        <li><a href={`${base}act/`}>Take Action</a></li>
        <li><a href={`${base}act/`} class="act-link">Sign the Petition</a></li>
      </ul>
    </div>
  </nav>

  <slot />

  <footer class="footer">
    <p><strong>DeFlock Safford</strong></p>
    <p>A project of The Mnemosyne Research Institute &middot; Graham County, Arizona</p>
    <p style="font-size:0.78rem; color:#9fb4d0; margin-top:0.4rem;">
      This is an independent residents' advocacy site. It is not affiliated with, endorsed by, or operated by the City of Safford or Graham County government.
    </p>
    <div class="footer-links">
      <a href={base}>The Problem</a> &middot;
      <a href={`${base}proof/`}>Proof It Works</a> &middot;
      <a href={`${base}act/`}>Take Action</a>
    </div>
    <p style="margin-top:1rem; font-size:0.75rem; color:#555;">
      Every claim on this site is sourced to primary documents or major reporting. Found an error? That matters to us. Report it.
    </p>
  </footer>

  <script>
    document.getElementById('menu-toggle')?.addEventListener('click', () => {
      document.getElementById('nav-links')?.classList.toggle('open');
    });
  </script>
</body>
</html>
