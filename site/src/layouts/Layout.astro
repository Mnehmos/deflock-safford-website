---
interface Props {
  title: string;
  description?: string;
  accent?: string;
}

const {
  title,
  description = "DeFlock Safford — Mass surveillance came to Graham County. Here's what it does, who can see it, and how to push back.",
  accent = "#E63946"
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | DeFlock Safford</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style is:global define:vars={{ accent }}>
    :root {
      --color-bg: #0a0a0a;
      --color-surface: #141414;
      --color-text: #e8e8e8;
      --color-muted: #888;
      --color-accent: var(--accent);
      --font-heading: 'Space Grotesk', system-ui, sans-serif;
      --font-body: 'Inter', system-ui, sans-serif;
      --max-width: 720px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 1.0625rem;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 { font-family: var(--font-heading); line-height: 1.2; }
    h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; }
    h2 { font-size: 1.75rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--color-accent); }
    h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; }

    p { margin-bottom: 1rem; }
    a { color: var(--color-accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    blockquote {
      border-left: 3px solid var(--color-accent);
      padding-left: 1.5rem;
      margin: 1.5rem 0;
      color: var(--color-muted);
      font-style: italic;
    }

    code {
      font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', monospace;
      font-size: 0.9em;
      background: #1d1d1d;
      padding: 0.1rem 0.35rem;
      border-radius: 3px;
      color: #e8e8e8;
    }

    /* NAV */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid #222;
    }
    .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 0.75rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--color-accent);
    }
    .nav-brand:hover { text-decoration: none; }
    .nav-links {
      list-style: none;
      display: flex;
      gap: 0.9rem;
      align-items: center;
    }
    .nav-links a {
      font-size: 0.85rem;
      color: var(--color-muted);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--color-text); text-decoration: none; }
    .nav-links .act-link {
      background: var(--color-accent);
      color: var(--color-bg);
      padding: 0.4rem 0.9rem;
      border-radius: 4px;
      font-weight: 600;
    }
    .nav-links .act-link:hover { opacity: 0.9; }

    /* DROPDOWN */
    .nav-dropdown { position: relative; }
    .nav-dropdown-toggle { cursor: pointer; }
    .dropdown-arrow { font-size: 0.65em; margin-left: 2px; }
    .nav-dropdown-menu {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      background: #141414;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 0.5rem 0;
      min-width: 200px;
      list-style: none;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      z-index: 200;
    }
    .nav-dropdown-menu::before {
      content: '';
      position: absolute;
      top: -0.5rem; left: 0; right: 0; height: 0.5rem;
    }
    .nav-dropdown:hover .nav-dropdown-menu { display: block; }
    .nav-dropdown-menu li { list-style: none; }
    .nav-dropdown-menu a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 1rem;
      font-size: 0.85rem;
      color: var(--color-muted);
      white-space: nowrap;
      transition: color 0.15s, background 0.15s;
    }
    .nav-dropdown-menu a:hover { color: var(--color-text); background: rgba(255,255,255,0.05); }
    .nav-dot {
      display: inline-block; width: 8px; height: 8px;
      border-radius: 50%; flex-shrink: 0;
    }

    .hamburger {
      display: none; background: none; border: none;
      color: var(--color-text); font-size: 1.5rem; cursor: pointer;
    }

    /* MAIN CONTENT */
    .content { max-width: var(--max-width); margin: 0 auto; padding: 3rem 1.5rem; }

    .hero {
      text-align: center;
      padding: 4rem 1.5rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .hero .tagline {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--color-muted);
      margin-bottom: 0.5rem;
    }
    .hero h1 { font-size: 3rem; }
    .hero .subtitle {
      font-size: 1.25rem;
      color: var(--color-muted);
      max-width: 620px;
      margin: 1.5rem auto;
    }

    /* BUTTONS */
    .btn {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: var(--color-accent);
      color: var(--color-bg);
      font-weight: 600;
      font-family: var(--font-heading);
      border-radius: 4px;
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
      margin: 0.5rem;
    }
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(230, 57, 70, 0.3);
      text-decoration: none;
    }
    .btn-outline {
      background: transparent;
      border: 2px solid var(--color-accent);
      color: var(--color-accent);
    }

    /* RECEIPT / FACT CARD */
    .card {
      background: var(--color-surface);
      border: 1px solid #222;
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
      transition: border-color 0.2s;
      text-decoration: none;
      display: block;
      color: inherit;
    }
    .card:hover { border-color: var(--color-accent); text-decoration: none; }
    .card h3 { margin-top: 0; color: var(--color-text); }
    .card p { color: var(--color-muted); margin-bottom: 0.75rem; }
    .card-specifics { list-style: none; padding: 0; margin: 0; }
    .card-specifics li {
      position: relative;
      padding-left: 1.25rem;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      color: var(--color-muted);
      line-height: 1.5;
    }
    .card-specifics li::before {
      content: '\2192';
      position: absolute; left: 0;
      color: var(--color-accent);
    }
    .card-specifics li strong { color: var(--color-text); }
    .card-tag {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 0.25rem 0.5rem;
      border-radius: 3px;
      margin-bottom: 0.75rem;
    }

    /* SOURCE LINE */
    .source {
      font-size: 0.8rem;
      color: #666;
      margin-top: 0.5rem;
      font-style: italic;
    }
    .source a { color: #888; }

    /* CTA BANNER */
    .cta-banner {
      background: var(--color-surface);
      border: 1px solid #333;
      border-radius: 8px;
      padding: 2rem;
      margin: 3rem 0;
      text-align: center;
    }
    .cta-banner h3 { color: var(--color-accent); margin-top: 0; }

    /* STAT */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin: 2rem 0;
    }
    .stat {
      background: var(--color-surface);
      padding: 1.25rem;
      border-radius: 8px;
      text-align: center;
    }
    .stat-number {
      font-family: var(--font-heading);
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-accent);
    }
    .stat-label { font-size: 0.85rem; color: var(--color-muted); }

    /* CODE BLOCK (for the records request) */
    .codeblock {
      background: #0d0d0d;
      border: 1px solid #2a2a2a;
      border-radius: 8px;
      padding: 1.5rem;
      margin: 1.5rem 0;
      font-family: ui-monospace, 'Cascadia Code', monospace;
      font-size: 0.85rem;
      line-height: 1.6;
      color: #d8d8d8;
      white-space: pre-wrap;
      overflow-x: auto;
    }

    /* CALENDAR VISUALIZER */
    .cal {
      background: var(--color-surface);
      border: 1px solid #222;
      border-radius: 8px;
      padding: 1.25rem;
      margin: 1rem 0;
    }
    .cal-title {
      font-family: var(--font-heading);
      font-weight: 600;
      text-align: center;
      margin-bottom: 0.75rem;
    }
    .cal-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
    }
    .cal-dow {
      text-align: center;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--color-muted);
      padding-bottom: 0.25rem;
    }
    .cal-day {
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      border-radius: 5px;
      color: var(--color-text);
    }
    .cal-day.empty { color: transparent; }
    .cal-day.meeting {
      background: var(--color-accent);
      color: var(--color-bg);
      font-weight: 700;
    }
    .cal-day.meeting-alt {
      border: 2px solid var(--color-accent);
      color: var(--color-accent);
      font-weight: 700;
    }
    .cal-legend {
      display: flex;
      gap: 1.25rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 0.85rem;
      font-size: 0.8rem;
      color: var(--color-muted);
    }
    .cal-legend span { display: inline-flex; align-items: center; gap: 0.4rem; }
    .cal-swatch { width: 14px; height: 14px; border-radius: 3px; display: inline-block; }

    /* FOOTER */
    .footer {
      margin-top: 4rem;
      padding: 2rem;
      background: var(--color-surface);
      text-align: center;
      font-size: 0.85rem;
      color: var(--color-muted);
      border-top: 1px solid #222;
    }
    .footer a { color: var(--color-accent); }
    .footer-links { margin-top: 1rem; }
    .footer-links a { margin: 0 0.5rem; }

    /* MOBILE */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 100%; left: 0; right: 0;
        background: var(--color-bg);
        border-bottom: 1px solid #222;
        padding: 1rem;
      }
      .hamburger { display: block; }
      .nav-dropdown-menu {
        position: static; transform: none;
        background: transparent; border: none;
        box-shadow: none; padding: 0 0 0 0.75rem; min-width: 0;
      }
      .nav-dropdown-menu::before { display: none; }
      .nav-links.open .nav-dropdown .nav-dropdown-menu { display: block; }
      .nav-dropdown-menu a { padding: 0.3rem 0.5rem; font-size: 0.8rem; }
      .hero h1 { font-size: 2rem; }
      h1 { font-size: 1.75rem; }
      h2 { font-size: 1.4rem; }
      .stat-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href={base} class="nav-brand">DeFlock Safford</a>
      <button class="hamburger" aria-label="Menu" id="menu-toggle">&#9776;</button>
      <ul class="nav-links" id="nav-links">
        <li class="nav-dropdown">
          <a href={`${base}cameras/`} class="nav-dropdown-toggle">Learn <span class="dropdown-arrow">&#9662;</span></a>
          <ul class="nav-dropdown-menu">
            <li><a href={`${base}cameras/`}><span class="nav-dot" style="background:#E63946;"></span> What Flock Really Is</a></li>
            <li><a href={`${base}network/`}><span class="nav-dot" style="background:#F4A261;"></span> The Network &amp; The Abuse</a></li>
            <li><a href={`${base}architecture/`}><span class="nav-dot" style="background:#9D4EDD;"></span> Flock to Palantir</a></li>
            <li><a href={`${base}kill-chain/`}><span class="nav-dot" style="background:#9D4EDD;"></span> The Kill Chain Comes Home</a></li>
          </ul>
        </li>
        <li><a href={`${base}safford/`}>Local</a></li>
        <li class="nav-dropdown">
          <a href={`${base}records/`} class="nav-dropdown-toggle">Act <span class="dropdown-arrow">&#9662;</span></a>
          <ul class="nav-dropdown-menu">
            <li><a href={`${base}petition/`}><span class="nav-dot" style="background:#E63946;"></span> Sign the Petition</a></li>
            <li><a href={`${base}records/`}><span class="nav-dot" style="background:#2A9D8F;"></span> Records Request</a></li>
            <li><a href={`${base}meetings/`}><span class="nav-dot" style="background:#2A9D8F;"></span> Meeting Schedule</a></li>
            <li><a href={`${base}organize/`}><span class="nav-dot" style="background:#2A9D8F;"></span> How To Organize</a></li>
          </ul>
        </li>
        <li><a href={`${base}resources/`}>Resources</a></li>
        <li><a href={`${base}about/`}>About</a></li>
        <li><a href={`${base}petition/`} class="act-link">Sign the Petition</a></li>
      </ul>
    </div>
  </nav>

  <slot />

  <footer class="footer">
    <p><strong>DeFlock Safford</strong></p>
    <p>A project of The Mnemosyne Research Institute &middot; Graham County, Arizona</p>
    <div class="footer-links">
      <a href={`${base}cameras/`}>Learn</a> &middot;
      <a href={`${base}safford/`}>Local</a> &middot;
      <a href={`${base}records/`}>Act</a> &middot;
      <a href={`${base}about/`}>About</a>
    </div>
    <p style="margin-top:1rem; font-size:0.75rem; color:#555;">
      Every claim on this site is sourced to primary documents or major reporting. Found an error? That matters to us. Report it.
    </p>
  </footer>

  <script>
    document.getElementById('menu-toggle')?.addEventListener('click', () => {
      document.getElementById('nav-links')?.classList.toggle('open');
    });
  </script>
</body>
</html>
